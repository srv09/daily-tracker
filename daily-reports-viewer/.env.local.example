# Secret that reporter.py sends in x-reports-secret header to POST reports
REPORTS_API_SECRET=pick-any-random-string

# Local: path to ~/daily-reports/ (auto-detected, change only if needed)
# REPORTS_DIR=/Users/your-name/daily-reports

# Vercel KV (only needed when deploying to Vercel):
# These are auto-populated when you connect a KV database in the Vercel dashboard.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
