# ByteDance Ark API key — get one at https://console.volcengine.com/ark
BYTEDANCE_API_KEY=your-key-here

# Model to use (default: seed-2-0-mini-260428)
# BYTEDANCE_MODEL=seed-2-0-mini-260428

# API endpoint (default: Southeast Asia region)
# BYTEDANCE_API_URL=https://ark.ap-southeast.bytepluses.com/api/v3/responses

# Optional — set these after deploying daily-reports-viewer to Vercel
# REPORTS_API_URL=https://your-app.vercel.app
# REPORTS_API_SECRET=pick-any-random-string
